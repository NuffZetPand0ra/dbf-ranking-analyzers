{
  "name": "dbf-ranking-analyzers",
  "version": "1.0.0",
  "private": true,
  "description": "Static analyzers for DBF handicap views",
  "scripts": {
    "build": "eleventy",
    "dev": "concurrently -k -n site,relay \"npm:dev:site\" \"npm:dev:relay\"",
    "dev:site": "eleventy --watch",
    "dev:relay": "PORT=4173 OPEN_ROUTE=/ node server.js",
    "dev:dashboard": "npm run dev",
    "dev:handicap": "concurrently -k -n site,relay \"npm:dev:site\" \"PORT=4174 OPEN_ROUTE=/tools/handicap-comparison/ node server.js\"",
    "dev:histogram": "concurrently -k -n site,relay \"npm:dev:site\" \"PORT=4175 OPEN_ROUTE=/tools/handicap-distribution/ node server.js\"",
    "dev:badge": "concurrently -k -n site,relay \"npm:dev:site\" \"PORT=4176 OPEN_ROUTE=/tools/player-badge/ node server.js\"",
    "dev:if-only": "concurrently -k -n site,relay \"npm:dev:site\" \"PORT=4177 OPEN_ROUTE=/tools/if-only/ node server.js\"",
    "preview": "npm run build && PORT=4173 OPEN_ROUTE=/ node server.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-handlebars": "^1.0.0",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  }
}
