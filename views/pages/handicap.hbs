<main class="page">
<header>
  {{> analyzer_header headerRowClass="page-header" title="DBf Handicap Sammenligning" titleClass="page-title" subtitle="Analyser udvikling for flere spillere i samme chart." subtitleClass="page-subtitle"}}
</header>

<div class="top-bar">
  <div class="file-zone">
    <span>Spillere</span>
    <div class="file-row" id="pill-row"></div>
    <div class="fetch-row">
      <span class="lbl">Hent spiller fra DBfNr</span>
      <div class="fetch-controls">
        <div class="autocomplete-wrapper">
          <input type="text" id="dbf-number" placeholder="Søg efter spiller..." aria-label="Søg spiller" autocomplete="off">
          <div class="autocomplete-dropdown" id="autocomplete-dropdown" style="display:none"></div>
        </div>
        <span class="add-btn" id="fetch-player-btn">+ Hent fra DBf</span>
        <span class="clear-btn" id="clear-player-cache-btn">Ryd cache</span>
        <span class="fetch-status" id="fetch-player-status"></span>
      </div>
    </div>
  </div>
  <div class="filter-zone">
    <div><span class="lbl">Fra dato</span><input type="date" id="from-date"></div>
    <div><span class="lbl">Til dato</span><input type="date" id="to-date"></div>
    <div><span class="lbl">Tidsperiode</span>
      <select id="date-preset">
        <option value="">Vælg periode...</option>
        <option value="1">1 måned</option>
        <option value="2">2 måneder</option>
        <option value="3">3 måneder</option>
        <option value="6">6 måneder</option>
        <option value="12">12 måneder</option>
        <option value="24">2 år</option>
        <option value="36">3 år</option>
      </select>
    </div>
    <div><span class="lbl">Vis pr.</span>
      <select id="granularity">
        <option value="all">Alle poster</option>
        <option value="week">Uge</option>
        <option value="month" selected>Måned</option>
        <option value="quarter">Kvartal</option>
        <option value="year">År</option>
      </select>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <span class="lbl">Smooth</span>
      <input type="range" id="tension" min="0" max="0.5" step="0.05" value="0.1" style="width:80px">
    </div>
  </div>
</div>

<div class="controls-row">
  <span class="lbl" style="margin:0">Vis:</span>
  <span class="toggle-btn on" id="toggle-points">Punkter</span>
  <span class="toggle-btn on" id="toggle-hover">Hover tooltip</span>
  <span class="add-btn" id="share-link-btn">Del link</span>
  <span class="add-btn" id="export-chart-btn">💾 Gem diagram</span>
  <label class="share-opt"><input type="checkbox" id="include-end-date"> Inkluder slutdato</label>
</div>

<div class="legend" id="legend"></div>
<div id="empty-msg" class="empty">
  Hent spillere ved at søge ovenfor.
</div>
<div class="chart-wrap" id="chart-wrap" style="display:none"><canvas id="myChart"></canvas></div>
<div class="stats-row" id="stats-row"></div>

{{> footer wrapperClass="page-footer"}}

</main>