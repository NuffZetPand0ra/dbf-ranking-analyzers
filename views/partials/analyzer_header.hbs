<div{{#if headerRowClass}} class="{{headerRowClass}}"{{/if}}>
  <div>
    <h1{{#if titleClass}} class="{{titleClass}}"{{/if}}>{{title}}</h1>
    {{#if subtitle}}
    <p{{#if subtitleId}} id="{{subtitleId}}"{{/if}}{{#if subtitleClass}} class="{{subtitleClass}}"{{/if}}>{{subtitle}}</p>
    {{/if}}
  </div>
  <div class="header-tools">
    <a href="./dbf_dashboard.html" class="back-link" aria-label="Til forsiden">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
      Forside
    </a>
    <div id="theme-toggle-slot"></div>
  </div>
</div>
